# Zoho CRM OAuth credentials for FC-FCA-01 reconstruction
# Copy this file to scripts/.env (which is gitignored) and fill in the real values.

# OAuth app client credentials (from Zoho Developer Console)
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=

# Refresh token issued for this OAuth app, scoped:
#   ZohoCRM.modules.contacts.READ,ZohoCRM.coql.READ,ZohoSearch.securesearch.READ
ZOHO_REFRESH_TOKEN=

# Data centre. EU for fairfinanceclaims.com (per Desk + Analytics URLs).
# Allowed: eu, com, in, com.au, jp
ZOHO_DC=eu
